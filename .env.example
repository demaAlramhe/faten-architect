# Optional: site URL for SEO (sitemap, OpenGraph)
# NEXT_PUBLIC_SITE_URL=https://faten-architect.co.il

# Optional: Cloudflare Turnstile (captcha) – get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# Without these, the contact form works without captcha.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key
# TURNSTILE_SECRET_KEY=your_secret_key
